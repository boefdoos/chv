---
interface Props {
  title: string;
  description?: string;
  activeNav?: string;
  canonical?: string;
}

const { title, description = 'Wetenschappelijk onderbouwde informatie over chronische hyperventilatie', activeNav = '', canonical = '' } = Astro.props;
const siteUrl = 'https://www.chronische-hyperventilatie.be';
const pageUrl = canonical ? `${siteUrl}${canonical}` : siteUrl;
const fullTitle = title === 'Home' ? 'Chronische Hyperventilatie | Wetenschappelijk onderbouwde informatie' : `${title} | Chronische Hyperventilatie`;
---

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="canonical" href={pageUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:locale" content="nl_BE" />
  <meta property="og:site_name" content="Chronische Hyperventilatie" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />

  <!-- Extra SEO -->
  <meta name="robots" content="index, follow" />
  <meta name="language" content="nl-BE" />
  <link rel="sitemap" href="/sitemap.xml" />
  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'MedicalWebPage',
    'name': fullTitle,
    'description': description,
    'url': pageUrl,
    'inLanguage': 'nl-BE',
    'about': {
      '@type': 'MedicalCondition',
      'name': 'Chronische Hyperventilatie',
      'alternateName': 'Chronisch Hyperventilatie Syndroom'
    },
    'publisher': {
      '@type': 'Organization',
      'name': 'BreathWise Research',
      'url': siteUrl
    },
    'lastReviewed': '2026-03'
  })} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;1,9..144,400&family=Outfit:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <nav class="max-w-[1200px] mx-auto px-6 md:px-12 py-6 flex items-center justify-between">
    <a href="/" class="font-serif text-[17px] text-sand-700 no-underline">
      Chronische Hyperventilatie
    </a>
    <!-- Hamburger button -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-[5px] p-2 bg-transparent border-none cursor-pointer">
      <span class="block w-5 h-[1.5px] bg-sand-600 transition-all" id="ham-1"></span>
      <span class="block w-5 h-[1.5px] bg-sand-600 transition-all" id="ham-2"></span>
      <span class="block w-5 h-[1.5px] bg-sand-600 transition-all" id="ham-3"></span>
    </button>

    <ul class="hidden md:flex gap-7 list-none items-center">
      <li class="relative" id="nav-dropdown">
        <button class:list={["text-sm transition-colors flex items-center gap-1 bg-transparent border-none cursor-pointer font-sans", activeNav === 'wat-is-het' ? 'text-sand-700 font-medium' : 'text-sand-500 hover:text-sage-300']} id="nav-dropdown-btn">
          Wat is het?
          <svg class="w-3 h-3 transition-transform" id="nav-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="absolute top-full left-0 mt-2 w-[240px] bg-sand-50 border border-sand-300 rounded-xl shadow-lg opacity-0 invisible transition-all duration-200 z-50" id="nav-dropdown-menu">
          <div class="py-2">
            <a href="/wat-is-het/ademhaling" class="block px-4 py-2.5 text-[13px] text-sand-600 no-underline hover:bg-sand-200 hover:text-sand-700 transition-colors">Hoe werkt ademhaling?</a>
            <a href="/wat-is-het/wat-gaat-er-mis" class="block px-4 py-2.5 text-[13px] text-sand-600 no-underline hover:bg-sand-200 hover:text-sand-700 transition-colors">Wat gaat er mis?</a>
            <a href="/diagnose" class="block px-4 py-2.5 text-[13px] text-sand-600 no-underline hover:bg-sand-200 hover:text-sand-700 transition-colors">Diagnose</a>
          </div>
        </div>
      </li>
      <li><a href="/behandeling" class:list={["text-sm no-underline transition-colors", activeNav === 'behandeling' ? 'text-sand-700 font-medium' : 'text-sand-500 hover:text-sage-300']}>Behandeling</a></li>
      <li><a href="/leven-met-chv" class:list={["text-sm no-underline transition-colors", activeNav === 'leven-met-chv' ? 'text-sand-700 font-medium' : 'text-sand-500 hover:text-sage-300']}>Leven met CHV</a></li>
      <li><a href="/zorgverleners" class="text-sm no-underline text-sage-300 font-medium border border-sage-50 px-3.5 py-1.5 rounded-lg hover:bg-sage-50 transition-all">Voor zorgverleners</a></li>
    </ul>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden fixed inset-0 top-[60px] bg-sand-50 z-40 px-6 py-8 hidden">
      <ul class="list-none space-y-1">
        <li><a href="/wat-is-het/ademhaling" class="block py-3 text-[15px] text-sand-600 no-underline border-b border-sand-200">Hoe werkt ademhaling?</a></li>
        <li><a href="/wat-is-het/wat-gaat-er-mis" class="block py-3 text-[15px] text-sand-600 no-underline border-b border-sand-200">Wat gaat er mis?</a></li>
        <li><a href="/diagnose" class="block py-3 text-[15px] text-sand-600 no-underline border-b border-sand-200">Diagnose</a></li>
        <li><a href="/behandeling" class="block py-3 text-[15px] text-sand-600 no-underline border-b border-sand-200">Behandeling</a></li>
        <li><a href="/leven-met-chv" class="block py-3 text-[15px] text-sand-600 no-underline border-b border-sand-200">Leven met CHV</a></li>
        <li class="pt-3"><a href="/zorgverleners" class="inline-block text-sm no-underline text-sage-300 font-medium border border-sage-50 px-3.5 py-1.5 rounded-lg">Voor zorgverleners</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <style is:global>
    @import '../styles/global.css';
  </style>

  <footer class="border-t border-sand-300 mt-10 py-8 px-6 md:px-12">
    <div class="max-w-[1200px] mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-[13px] text-sand-500 leading-relaxed text-center md:text-left">
        Niets op deze site is bedoeld als medisch advies. Raadpleeg altijd een arts of therapeut.
      </p>
      <div class="flex items-center gap-5 text-[13px] text-sand-500">
        <a href="mailto:troostberg@gmail.com" class="no-underline text-sand-500 hover:text-sage-300 transition-colors">Contact</a>
        <a href="/privacy" class="no-underline text-sand-500 hover:text-sage-300 transition-colors">Privacy</a>
      </div>
    </div>
  </footer>

  <!-- Cookie banner -->
  <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-50 bg-sand-50 border-t border-sand-300 shadow-lg transition-transform duration-300" style="transform: translateY(100%)">
    <div class="max-w-[1200px] mx-auto px-6 md:px-12 py-4 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-[13px] text-sand-600 leading-relaxed">
        Deze site gebruikt geen tracking cookies. We gebruiken alleen functionele cookies voor de werking van de site.
        <a href="/privacy" class="text-sage-300 no-underline hover:underline">Meer info</a>
      </p>
      <button id="cookie-accept" class="shrink-0 px-5 py-2 text-[13px] font-medium bg-sage-300 text-white rounded-lg hover:bg-sage-400 transition-colors cursor-pointer border-none">
        Begrepen
      </button>
    </div>
  </div>

  <script>
    // Scroll reveal observer
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // Dropdown nav
    const dropdownBtn = document.getElementById('nav-dropdown-btn');
    const dropdownMenu = document.getElementById('nav-dropdown-menu');
    const chevron = document.getElementById('nav-chevron');
    let dropdownOpen = false;

    function toggleDropdown() {
      dropdownOpen = !dropdownOpen;
      if (dropdownOpen) {
        dropdownMenu.style.opacity = '1';
        dropdownMenu.style.visibility = 'visible';
        chevron.style.transform = 'rotate(180deg)';
      } else {
        dropdownMenu.style.opacity = '0';
        dropdownMenu.style.visibility = 'hidden';
        chevron.style.transform = 'rotate(0)';
      }
    }

    dropdownBtn?.addEventListener('click', toggleDropdown);

    document.addEventListener('click', (e) => {
      if (dropdownOpen && !document.getElementById('nav-dropdown')?.contains(e.target)) {
        toggleDropdown();
      }
    });

    // Mobile menu
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const ham1 = document.getElementById('ham-1');
    const ham2 = document.getElementById('ham-2');
    const ham3 = document.getElementById('ham-3');
    let mobileMenuOpen = false;

    mobileMenuBtn?.addEventListener('click', () => {
      mobileMenuOpen = !mobileMenuOpen;
      if (mobileMenuOpen) {
        mobileMenu?.classList.remove('hidden');
        if (ham1) { ham1.style.transform = 'rotate(45deg) translate(2px, 3px)'; }
        if (ham2) { ham2.style.opacity = '0'; }
        if (ham3) { ham3.style.transform = 'rotate(-45deg) translate(2px, -3px)'; }
      } else {
        mobileMenu?.classList.add('hidden');
        if (ham1) { ham1.style.transform = 'none'; }
        if (ham2) { ham2.style.opacity = '1'; }
        if (ham3) { ham3.style.transform = 'none'; }
      }
    });

    // Cookie banner
    const cookieBanner = document.getElementById('cookie-banner');
    const cookieAccept = document.getElementById('cookie-accept');

    if (!localStorage.getItem('cookie-accepted')) {
      setTimeout(() => {
        if (cookieBanner) cookieBanner.style.transform = 'translateY(0)';
      }, 1000);
    }

    cookieAccept?.addEventListener('click', () => {
      localStorage.setItem('cookie-accepted', 'true');
      if (cookieBanner) cookieBanner.style.transform = 'translateY(100%)';
    });
  </script>
</body>
</html>
